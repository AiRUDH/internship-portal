rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PUBLIC READ — only admin UID can write/delete
    match /listings/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
                   request.auth.uid == "1ZvaGaS6tQbM64Tlaxtf6u8T5v02";
    }

    // APPLICATIONS — anyone can submit, only admin can read/delete
    match /applications/{doc} {
      allow create: if true;
      allow read, delete: if request.auth != null &&
                         request.auth.uid == "1ZvaGaS6tQbM64Tlaxtf6u8T5v02";
    }
  }
}
