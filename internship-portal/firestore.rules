rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PUBLIC READ — only admin UID can add/delete internships
    match /internships/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
                   request.auth.uid == "1ZvaGaS6tQbM64Tlaxtf6u8T5v02";
    }

    // APPLICATIONS — anyone can submit, only admin can read/update/delete
    match /applications/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
                                  request.auth.uid == "1ZvaGaS6tQbM64Tlaxtf6u8T5v02";
    }
  }
}
